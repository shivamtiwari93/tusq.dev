{
  "schema_version": "1.0",
  "template": "cli-tool",
  "project": {
    "id": "tusq-dev",
    "name": "tusq.dev",
    "goal": "Build tusq.dev as the open-source capability compiler and governed AI-enablement engine for SaaS products.",
    "default_branch": "main"
  },
  "roles": {
    "pm": {
      "title": "Product Manager",
      "mandate": "Protect user value, scope clarity, and acceptance criteria.",
      "write_authority": "authoritative",
      "runtime": "local-pm"
    },
    "dev": {
      "title": "Developer",
      "mandate": "Implement approved work safely and verify behavior.",
      "write_authority": "authoritative",
      "runtime": "local-dev",
      "runtime_id": "local-dev"
    },
    "qa": {
      "title": "QA",
      "mandate": "Challenge correctness, acceptance coverage, and ship readiness.",
      "write_authority": "authoritative",
      "runtime": "local-director",
      "runtime_id": "local-director"
    },
    "product_marketing": {
      "title": "Staff Product Marketing Manager",
      "mandate": "Sharpen positioning, launch clarity, and market-facing narrative without drifting from product truth.",
      "write_authority": "authoritative",
      "runtime": "local-director",
      "runtime_id": "local-director"
    },
    "eng_director": {
      "title": "Engineering Director",
      "mandate": "Resolve tactical deadlocks and enforce technical coherence.",
      "write_authority": "authoritative",
      "runtime": "local-director"
    }
  },
  "runtimes": {
    "local-pm": {
      "type": "local_cli",
      "command": [
        "claude",
        "--print",
        "--effort",
        "high",
        "--permission-mode",
        "bypassPermissions",
        "--model",
        "claude-opus-4-7",
        "--output-format",
        "stream-json",
        "--include-partial-messages",
        "--verbose",
        "--dangerously-skip-permissions"
      ],
      "cwd": ".",
      "prompt_transport": "stdin"
    },
    "local-dev": {
      "type": "local_cli",
      "command": [
        "claude",
        "--print",
        "--effort",
        "high",
        "--permission-mode",
        "bypassPermissions",
        "--model",
        "claude-sonnet-4-6",
        "--output-format",
        "stream-json",
        "--include-partial-messages",
        "--verbose",
        "--dangerously-skip-permissions"
      ],
      "cwd": ".",
      "prompt_transport": "stdin"
    },
    "local-qa": {
      "type": "local_cli",
      "command": [
        "claude",
        "--print",
        "--effort",
        "high",
        "--permission-mode",
        "bypassPermissions",
        "--model",
        "claude-sonnet-4-6",
        "--output-format",
        "stream-json",
        "--include-partial-messages",
        "--verbose",
        "--dangerously-skip-permissions"
      ],
      "cwd": ".",
      "prompt_transport": "stdin"
    },
    "local-product-marketing": {
      "type": "local_cli",
      "command": [
        "claude",
        "--print",
        "--effort",
        "high",
        "--permission-mode",
        "bypassPermissions",
        "--model",
        "claude-opus-4-7",
        "--output-format",
        "stream-json",
        "--include-partial-messages",
        "--verbose",
        "--dangerously-skip-permissions"
      ],
      "cwd": ".",
      "prompt_transport": "stdin"
    },
    "local-director": {
      "type": "local_cli",
      "command": [
        "/Applications/Codex.app/Contents/Resources/codex",
        "exec",
        "--dangerously-bypass-approvals-and-sandbox",
        "-c",
        "model_reasoning_effort=\"high\"",
        "--model",
        "gpt-5.4"
      ],
      "cwd": ".",
      "prompt_transport": "stdin"
    }
  },
  "routing": {
    "planning": {
      "entry_role": "pm",
      "allowed_next_roles": [
        "pm",
        "dev",
        "product_marketing",
        "eng_director",
        "human"
      ],
      "exit_gate": "planning_signoff"
    },
    "implementation": {
      "entry_role": "dev",
      "allowed_next_roles": [
        "dev",
        "qa",
        "product_marketing",
        "eng_director",
        "human"
      ],
      "exit_gate": "implementation_complete"
    },
    "qa": {
      "entry_role": "qa",
      "allowed_next_roles": [
        "dev",
        "qa",
        "product_marketing",
        "eng_director",
        "human"
      ],
      "exit_gate": "qa_ship_verdict"
    },
    "launch": {
      "entry_role": "product_marketing",
      "allowed_next_roles": [
        "product_marketing",
        "dev",
        "qa",
        "pm",
        "eng_director",
        "human"
      ],
      "exit_gate": "launch_ready"
    }
  },
  "gates": {
    "planning_signoff": {
      "requires_files": [
        ".planning/PM_SIGNOFF.md",
        ".planning/ROADMAP.md",
        ".planning/SYSTEM_SPEC.md"
      ],
      "requires_human_approval": true
    },
    "implementation_complete": {
      "requires_files": [
        ".planning/IMPLEMENTATION_NOTES.md"
      ],
      "requires_verification_pass": true
    },
    "qa_ship_verdict": {
      "requires_files": [
        ".planning/acceptance-matrix.md",
        ".planning/ship-verdict.md",
        ".planning/RELEASE_NOTES.md"
      ],
      "requires_human_approval": true
    },
    "launch_ready": {
      "requires_files": [
        ".planning/MESSAGING.md",
        ".planning/LAUNCH_PLAN.md",
        ".planning/CONTENT_CALENDAR.md",
        ".planning/ANNOUNCEMENT.md"
      ]
    }
  },
  "workflow_kit": {
    "phases": {
      "planning": {
        "artifacts": [
          {
            "path": ".planning/PM_SIGNOFF.md",
            "semantics": "pm_signoff",
            "required": true,
            "owned_by": "pm"
          },
          {
            "path": ".planning/ROADMAP.md",
            "semantics": null,
            "required": true,
            "owned_by": "pm"
          },
          {
            "path": ".planning/SYSTEM_SPEC.md",
            "semantics": "system_spec",
            "required": true,
            "owned_by": "pm"
          },
          {
            "path": ".planning/command-surface.md",
            "semantics": "section_check",
            "required": true,
            "owned_by": "pm",
            "semantics_config": {
              "required_sections": [
                "## Primary Commands",
                "## Flags And Options",
                "## Failure UX"
              ]
            }
          }
        ]
      },
      "implementation": {
        "artifacts": [
          {
            "path": ".planning/IMPLEMENTATION_NOTES.md",
            "semantics": "implementation_notes",
            "required": true,
            "owned_by": "dev"
          }
        ]
      },
      "qa": {
        "artifacts": [
          {
            "path": ".planning/acceptance-matrix.md",
            "semantics": "acceptance_matrix",
            "required": true,
            "owned_by": "qa"
          },
          {
            "path": ".planning/ship-verdict.md",
            "semantics": "ship_verdict",
            "required": true,
            "owned_by": "qa"
          },
          {
            "path": ".planning/RELEASE_NOTES.md",
            "semantics": "release_notes",
            "required": true,
            "owned_by": "qa"
          }
        ]
      },
      "launch": {
        "artifacts": [
          {
            "path": ".planning/MESSAGING.md",
            "semantics": "section_check",
            "required": true,
            "owned_by": "product_marketing",
            "semantics_config": {
              "required_sections": [
                "## Audience",
                "## Positioning",
                "## Product Truth",
                "## Claims We Can Defend",
                "## Claims We Must Not Make"
              ]
            }
          },
          {
            "path": ".planning/LAUNCH_PLAN.md",
            "semantics": "section_check",
            "required": true,
            "owned_by": "product_marketing",
            "semantics_config": {
              "required_sections": [
                "## Launch Goals",
                "## Required Assets",
                "## Dependencies",
                "## Risks"
              ]
            }
          },
          {
            "path": ".planning/CONTENT_CALENDAR.md",
            "semantics": "section_check",
            "required": true,
            "owned_by": "product_marketing",
            "semantics_config": {
              "required_sections": [
                "## Launch Day",
                "## Week 1",
                "## Follow-ups"
              ]
            }
          },
          {
            "path": ".planning/ANNOUNCEMENT.md",
            "semantics": "section_check",
            "required": true,
            "owned_by": "product_marketing",
            "semantics_config": {
              "required_sections": [
                "## Headline",
                "## Product Summary",
                "## Blog Draft",
                "## Social Copy"
              ]
            }
          }
        ]
      }
    }
  },
  "budget": {
    "per_turn_max_usd": 2,
    "per_run_max_usd": 50,
    "on_exceed": "pause_and_escalate"
  },
  "retention": {
    "talk_strategy": "append_only",
    "history_strategy": "jsonl_append_only"
  },
  "prompts": {
    "pm": ".agentxchain/prompts/pm.md",
    "dev": ".agentxchain/prompts/dev.md",
    "qa": ".agentxchain/prompts/qa.md",
    "product_marketing": ".agentxchain/prompts/product_marketing.md",
    "eng_director": ".agentxchain/prompts/eng_director.md"
  },
  "rules": {
    "challenge_required": true,
    "max_turn_retries": 2,
    "max_deadlock_cycles": 2
  }
}
